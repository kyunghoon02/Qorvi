FROM golang:1.24.4-bookworm AS builder

WORKDIR /src
COPY . .

RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -o /out/qorvi-api ./apps/api/cmd/api

FROM debian:bookworm-slim

RUN apt-get update \
  && apt-get install -y --no-install-recommends ca-certificates curl \
  && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY --from=builder /out/qorvi-api /app/qorvi-api

EXPOSE 4000

ENTRYPOINT ["/app/qorvi-api"]
