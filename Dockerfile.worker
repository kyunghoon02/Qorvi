FROM golang:1.24.4-bookworm AS build

WORKDIR /src

COPY go.work ./
COPY apps ./apps
COPY packages ./packages

RUN cd apps/workers && go build -o /out/qorvi-workers .

FROM debian:bookworm-slim AS runner

RUN apt-get update && \
    apt-get install -y --no-install-recommends ca-certificates && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY --from=build /out/qorvi-workers /app/qorvi-workers

CMD ["/app/qorvi-workers"]
