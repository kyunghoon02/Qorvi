FROM golang:1.24.4-bookworm AS builder

WORKDIR /src
COPY . .

RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -o /out/qorvi-workers ./apps/workers

FROM debian:bookworm-slim

RUN apt-get update \
  && apt-get install -y --no-install-recommends ca-certificates curl \
  && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY --from=builder /out/qorvi-workers /app/qorvi-workers
COPY infra/seeds /app/infra/seeds

ENTRYPOINT ["/app/qorvi-workers"]
