# Local development example.
NODE_ENV=development
LOG_LEVEL=info
APP_BASE_URL=http://localhost:3000
NEXT_PUBLIC_APP_BASE_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
API_PROXY_TARGET=http://localhost:4000
API_HOST=0.0.0.0
API_PORT=4000
POSTGRES_URL=postgres://postgres:postgres@localhost:5433/qorvi
NEO4J_URL=bolt://localhost:8687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=neo4jpassword
REDIS_URL=redis://localhost:6379
QORVI_WORKER_MODE=wallet-backfill-drain-batch
QORVI_DEV_STACK_WORKER_MODES=wallet-backfill-drain-batch,wallet-tracking-subscription-sync
# Optional: Mobula smart money polling uses a slower interval to avoid burning free credits.
QORVI_DEV_STACK_MOBULA_INTERVAL_SECONDS=1800
QORVI_RAW_PAYLOAD_ROOT=.qorvi/raw-payloads
QORVI_SEED_DISCOVERY_TOP_N=10
QORVI_SEED_DISCOVERY_MIN_CONFIDENCE=0.8
AUTH_PROVIDER=clerk
AUTH_SECRET=replace-me
CLERK_SECRET_KEY=replace-me
# Optional: if unset, derived from NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY.
CLERK_ISSUER_URL=
CLERK_JWKS_URL=
CLERK_AUDIENCE=qorvi
CLERK_CLOCK_SKEW_SECONDS=60
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=replace-me
STRIPE_SECRET_KEY=replace-me-stripe-secret
STRIPE_WEBHOOK_SECRET=replace-me-stripe-webhook
STRIPE_PUBLISHABLE_KEY=replace-me-stripe-publishable
STRIPE_BASE_URL=
STRIPE_SUCCESS_URL=http://localhost:3000/account?checkout=success
STRIPE_CANCEL_URL=http://localhost:3000/account?checkout=cancel
DUNE_API_KEY=replace-me-dune
DUNE_API_BASE_URL=https://api.dune.com/api/v1
DUNE_SEED_EXPORT_PATH=
DUNE_SEED_EXPORT_JSON=
QORVI_DUNE_QUERY_PRESET_PATH=queries/dune/backtest/query-presets.json
QORVI_DUNE_CANDIDATE_EXPORT_PATH=packages/intelligence/test/dune-backtest-candidates.json
QORVI_BACKTEST_MANIFEST_PATH=packages/intelligence/test/backtest-manifest.json
QORVI_ADMIN_ALLOWLIST_USER_IDS=
QORVI_ADMIN_ALLOWLIST_EMAILS=
ALCHEMY_API_KEY=replace-me-alchemy
HELIUS_API_KEY=replace-me-helius
MORALIS_API_KEY=replace-me-moralis
ALCHEMY_BASE_URL=https://eth-mainnet.g.alchemy.com
ALCHEMY_SOLANA_BASE_URL=https://solana-mainnet.g.alchemy.com
HELIUS_BASE_URL=https://api.helius.xyz
HELIUS_DATA_API_BASE_URL=https://api-mainnet.helius-rpc.com/v0
MOBULA_API_KEY=
MOBULA_BASE_URL=https://api.mobula.io
# Example:
# QORVI_MOBULA_SMART_MONEY_SEEDS_JSON='[{"blockchain":"ethereum","address":"0x6982508145454Ce325dDbE47a25d4ec3d2311933","tokenSymbol":"PEPE","labels":["smartTrader","proTrader"],"limit":25}]'
QORVI_MOBULA_SMART_MONEY_SEEDS_JSON=
# Moralis는 현재 체인별 node URL이 아니라 전역 API base URL 하나를 사용한다.
MORALIS_BASE_URL=https://deep-index.moralis.io/api/v2.2
# Optional: if set, tracking subscription sync will mark provider rows active and retain
# the provider webhook id in metadata. If unset, Qorvi will try to discover/create
# a provider webhook when QORVI_PROVIDER_WEBHOOK_BASE_URL is a public https URL.
ALCHEMY_ADDRESS_ACTIVITY_WEBHOOK_ID=
HELIUS_ADDRESS_ACTIVITY_WEBHOOK_ID=
# Optional: public https base URL used to auto-provision provider webhooks.
# In local dev leave this empty or set it to a tunnel/public origin.
QORVI_PROVIDER_WEBHOOK_BASE_URL=
# Optional: auth header value included by Helius webhook deliveries and verified by the API.
QORVI_PROVIDER_WEBHOOK_AUTH_HEADER=
# Optional: Alchemy network used when Qorvi auto-creates an address activity webhook.
ALCHEMY_ADDRESS_ACTIVITY_NETWORK=ETH_MAINNET
# Optional: required only if you want Qorvi to reconcile Alchemy tracked addresses
# against the remote webhook configuration.
ALCHEMY_NOTIFY_AUTH_TOKEN=
ALCHEMY_NOTIFY_BASE_URL=https://dashboard.alchemy.com
QORVI_ALERT_SMTP_HOST=
QORVI_ALERT_SMTP_PORT=587
QORVI_ALERT_SMTP_USERNAME=
QORVI_ALERT_SMTP_PASSWORD=
QORVI_ALERT_SMTP_FROM=alerts@qorvi.local
QORVI_ALERT_DELIVERY_RETRY_LIMIT=3
QORVI_ALERT_DELIVERY_RETRY_BATCH_LIMIT=25
QORVI_ALERT_DELIVERY_RETRY_BASE_DELAY_SECONDS=60
