NODE_ENV=development
LOG_LEVEL=info
APP_BASE_URL=http://localhost:3000
NEXT_PUBLIC_APP_BASE_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
API_PROXY_TARGET=http://localhost:4000
API_HOST=0.0.0.0
API_PORT=4000
POSTGRES_URL=postgres://postgres:postgres@localhost:5432/whalegraph
NEO4J_URL=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=neo4jpassword
REDIS_URL=redis://localhost:6379
WHALEGRAPH_WORKER_MODE=historical-backfill-fixture
WHALEGRAPH_RAW_PAYLOAD_ROOT=.whalegraph/raw-payloads
AUTH_PROVIDER=clerk
AUTH_SECRET=replace-me
CLERK_SECRET_KEY=replace-me
CLERK_ISSUER_URL=https://example.clerk.accounts.dev
CLERK_JWKS_URL=https://example.clerk.accounts.dev/.well-known/jwks.json
CLERK_AUDIENCE=whalegraph
CLERK_CLOCK_SKEW_SECONDS=60
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=replace-me
DUNE_API_KEY=replace-me-dune
ALCHEMY_API_KEY=replace-me-alchemy
HELIUS_API_KEY=replace-me-helius
MORALIS_API_KEY=replace-me-moralis
ALCHEMY_BASE_URL=https://eth-mainnet.g.alchemy.com
HELIUS_BASE_URL=https://api.helius.xyz
HELIUS_DATA_API_BASE_URL=https://api-mainnet.helius-rpc.com/v0
