NODE_ENV=development
LOG_LEVEL=info
APP_BASE_URL=http://localhost:3000
NEXT_PUBLIC_APP_BASE_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
API_PROXY_TARGET=http://localhost:4000
API_HOST=0.0.0.0
API_PORT=4000
