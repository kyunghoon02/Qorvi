# Production deployment example.
# Copy to a secure env store for the target production environment.

NODE_ENV=production
LOG_LEVEL=info

APP_BASE_URL=https://app.example.com
NEXT_PUBLIC_APP_BASE_URL=https://app.example.com
NEXT_PUBLIC_API_BASE_URL=https://api.example.com
API_PROXY_TARGET=https://api.example.com
API_HOST=0.0.0.0
API_PORT=4000

POSTGRES_URL=replace-me-postgres
NEO4J_URL=replace-me-neo4j
NEO4J_USERNAME=replace-me-neo4j-user
NEO4J_PASSWORD=replace-me-neo4j-password
REDIS_URL=replace-me-redis

QORVI_WORKER_MODE=wallet-backfill-drain-batch
QORVI_RAW_PAYLOAD_ROOT=/var/lib/qorvi/raw-payloads
QORVI_SEED_DISCOVERY_TOP_N=10
QORVI_SEED_DISCOVERY_MIN_CONFIDENCE=0.8

AUTH_PROVIDER=clerk
AUTH_SECRET=replace-me-auth-secret
CLERK_SECRET_KEY=replace-me-clerk-secret
# Optional: if unset, derived from NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY.
CLERK_ISSUER_URL=
CLERK_JWKS_URL=
CLERK_AUDIENCE=qorvi
CLERK_CLOCK_SKEW_SECONDS=60
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=replace-me-clerk-publishable

STRIPE_SECRET_KEY=replace-me-stripe-secret
STRIPE_WEBHOOK_SECRET=replace-me-stripe-webhook
STRIPE_PUBLISHABLE_KEY=replace-me-stripe-publishable
STRIPE_BASE_URL=
STRIPE_SUCCESS_URL=https://app.example.com/account?checkout=success
STRIPE_CANCEL_URL=https://app.example.com/account?checkout=cancel

DUNE_API_KEY=replace-me-dune
DUNE_SEED_EXPORT_PATH=
DUNE_SEED_EXPORT_JSON=

ALCHEMY_API_KEY=replace-me-alchemy
HELIUS_API_KEY=replace-me-helius
MORALIS_API_KEY=replace-me-moralis
ALCHEMY_BASE_URL=https://eth-mainnet.g.alchemy.com
ALCHEMY_SOLANA_BASE_URL=https://solana-mainnet.g.alchemy.com
HELIUS_BASE_URL=https://api.helius.xyz
HELIUS_DATA_API_BASE_URL=https://api-mainnet.helius-rpc.com/v0
MORALIS_BASE_URL=https://deep-index.moralis.io/api/v2.2
ALCHEMY_ADDRESS_ACTIVITY_WEBHOOK_ID=
HELIUS_ADDRESS_ACTIVITY_WEBHOOK_ID=
ALCHEMY_NOTIFY_AUTH_TOKEN=
ALCHEMY_NOTIFY_BASE_URL=https://dashboard.alchemy.com

QORVI_ALERT_SMTP_HOST=
QORVI_ALERT_SMTP_PORT=587
QORVI_ALERT_SMTP_USERNAME=
QORVI_ALERT_SMTP_PASSWORD=
QORVI_ALERT_SMTP_FROM=alerts@example.com
QORVI_ALERT_DELIVERY_RETRY_LIMIT=3
QORVI_ALERT_DELIVERY_RETRY_BATCH_LIMIT=25
QORVI_ALERT_DELIVERY_RETRY_BASE_DELAY_SECONDS=60
